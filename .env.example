# PostgreSQL only (required for Vercel). Free tier: https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
CRON_SECRET="random-secret-for-close-auctions-cron"
ALLOW_SIMULATE_PAY="false"

# Email (optional — without SMTP, emails log to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Jordan Market <noreply@yourdomain.com>"

# PayPal (sandbox or live)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL="https://api-m.sandbox.paypal.com"
PAYPAL_CURRENCY="USD"

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_CURRENCY="USD"

# Bank checkout copy shown to buyers
BANK_TRANSFER_INSTRUCTIONS="Wire the total to IBAN … use order id as reference."
